---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Daniel Blanco Martin | Cybersecurity Analyst' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portfolio de Daniel Blanco Martin — Analista de Ciberseguridad, Blue Team, SOC, Fortinet, SIEM." />
    <!-- Security headers -->
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=(), payment=()" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  /* Scroll reveal + skill bar fill + counter animations */
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        e.target.classList.add('vis');

        (e.target.querySelectorAll('.skill-fill') as NodeListOf<HTMLElement>).forEach((f) => {
          f.style.width = f.dataset.pct + '%';
        });

        (e.target.querySelectorAll('[data-count]') as NodeListOf<HTMLElement>).forEach((el) => {
          const target = +(el.dataset.count ?? 0);
          let n = 0;
          const tick = setInterval(() => {
            n = Math.min(n + 1, target);
            el.textContent = String(n);
            if (n >= target) clearInterval(tick);
          }, 60);
        });
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.rev, .rev-l, .rev-r').forEach((el) => observer.observe(el));
</script>
