---
const base = import.meta.env.BASE_URL;
---

<section id="certifications">
  <div class="container">
    <div class="sec-header rev">
      <div class="sec-label">// 04. CERTIFICACIONES</div>
      <h2 class="sec-title">Certificaciones Oficiales</h2>
      <p class="sec-desc">
        Credenciales obtenidas de las principales entidades de certificación en ciberseguridad y redes.
      </p>
    </div>
    <div class="certs-grid">

      <a class="cert-card rev d1"
         href="https://www.credly.com/badges/354be3e5-6167-43a6-bc8f-44ef22898d76/public_url"
         target="_blank" rel="noopener noreferrer">
        <div class="cert-top">
          <div class="cert-icon">
            <img src={`${base}img/ccna.jpg`} alt="CCNA" />
          </div>
          <span class="cert-badge cisco">CISCO</span>
        </div>
        <div class="cert-name">CISCO CERTIFIED NETWORK ASSOCIATE</div>
        <div class="cert-issuer">Cisco Systems · CCNA</div>
        <div class="cert-desc">
          Infraestructura de red empresarial: routing, switching, direccionamiento IP, VLANs, OSPF y
          seguridad en conectividad.
        </div>
        <div class="cert-tags">
          <span class="cert-tag">Routing</span>
          <span class="cert-tag">Switching</span>
          <span class="cert-tag">TCP/IP</span>
          <span class="cert-tag">OSPF</span>
          <span class="cert-tag">ACLs</span>
          <span class="cert-tag">VLANs</span>
        </div>
      </a>

      <a class="cert-card rev d2"
         href="https://www.credly.com/badges/8530bd0a-5bd9-4fb0-b1a9-84989f61c557/public_url"
         target="_blank" rel="noopener noreferrer">
        <div class="cert-top">
          <div class="cert-icon">
            <img src={`${base}img/cyberops.png`} alt="CyberOps Associate" />
          </div>
          <span class="cert-badge cyberops">CISCO</span>
        </div>
        <div class="cert-name">CCNA CYBERSECURITY — CyberOps Associate</div>
        <div class="cert-issuer">Cisco Systems · CCNACBR</div>
        <div class="cert-desc">
          Monitoreo de seguridad, detección de amenazas, análisis de intrusiones y respuesta operativa a
          incidentes en entornos SOC.
        </div>
        <div class="cert-tags">
          <span class="cert-tag">SOC Operations</span>
          <span class="cert-tag">Threat Hunting</span>
          <span class="cert-tag">IDS/IPS</span>
          <span class="cert-tag">Log Analysis</span>
        </div>
      </a>

      <a class="cert-card rev d1"
         href="https://www.credly.com/badges/01161d36-660d-4d15-9be7-0321c2d170e2/public_url"
         target="_blank" rel="noopener noreferrer">
        <div class="cert-top">
          <div class="cert-icon">
            <img src={`${base}img/comptia-aplus.png`} alt="CompTIA A+" />
          </div>
          <span class="cert-badge comptia">COMPTIA</span>
        </div>
        <div class="cert-name">CompTIA A+</div>
        <div class="cert-issuer">CompTIA · A+ ce</div>
        <div class="cert-desc">
          Soporte técnico, administración de sistemas HW/SW, redes básicas y resolución de incidencias
          bajo buenas prácticas de la industria.
        </div>
        <div class="cert-tags">
          <span class="cert-tag">IT Support</span>
          <span class="cert-tag">Hardware</span>
          <span class="cert-tag">Troubleshooting</span>
          <span class="cert-tag">OS Admin</span>
        </div>
      </a>

      <a class="cert-card rev d2"
         href="https://www.credly.com/badges/a065294a-baa3-4748-9571-6eca1a280b72/public_url"
         target="_blank" rel="noopener noreferrer">
        <div class="cert-top">
          <div class="cert-icon">
            <img src={`${base}img/sc900.svg`} alt="Microsoft SC-900" />
          </div>
          <span class="cert-badge microsoft">MICROSOFT</span>
        </div>
        <div class="cert-name">Security, Compliance &amp; Identity Fundamentals</div>
        <div class="cert-issuer">Microsoft Certified · SC-900</div>
        <div class="cert-desc">
          Gobierno de datos, cumplimiento normativo y protección de amenazas mediante Microsoft Entra ID,
          Sentinel y Microsoft Purview.
        </div>
        <div class="cert-tags">
          <span class="cert-tag">Entra ID</span>
          <span class="cert-tag">Sentinel</span>
          <span class="cert-tag">Compliance</span>
          <span class="cert-tag">Zero Trust</span>
          <span class="cert-tag">Purview</span>
        </div>
      </a>

      <a class="cert-card rev"
         href="https://www.credly.com/badges/ab0bed68-47b2-41a4-a77c-85e3d71e95a9/public_url"
         target="_blank" rel="noopener noreferrer">
        <div class="cert-top">
          <div class="cert-icon">
            <img src={`${base}img/fortinet.png`} alt="Fortinet FCP" />
          </div>
          <span class="cert-badge fortinet">FORTINET</span>
        </div>
        <div class="cert-name">FCP IN SECURITY OPERATIONS — NSE4 / NSE5</div>
        <div class="cert-issuer">Fortinet · FortiOS Administrator / FortiAnalyzer Analyst</div>
        <div class="cert-desc">
          Administración de seguridad perimetral (NGFW), alta disponibilidad (HA), arquitecturas SD-WAN y
          conectividad remota segura (VPN). Monitorización y análisis centralizado de logs mediante FortiOS
          y FortiAnalyzer.
        </div>
        <div class="cert-tags">
          <span class="cert-tag">NGFW</span>
          <span class="cert-tag">FortiOS</span>
          <span class="cert-tag">FortiAnalyzer</span>
          <span class="cert-tag">SD-WAN</span>
          <span class="cert-tag">High Availability</span>
          <span class="cert-tag">VPN IPSec</span>
          <span class="cert-tag">FSSO</span>
          <span class="cert-tag">Security Profiles</span>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  #certifications { background: var(--bg0); }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 1.5rem;
  }

  a.cert-card { color: inherit; }
  a.cert-card:hover { color: inherit; }

  .cert-card {
    background: rgba(0, 0, 0, 0.45);
    border: 1px solid var(--border);
    padding: 1.8rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
  }
  .cert-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 255, 136, 0.04), transparent 60%);
    pointer-events: none;
  }
  .cert-card::after {
    content: '';
    position: absolute;
    top: -100%;
    left: -100%;
    width: 300%;
    height: 300%;
    background: linear-gradient(105deg, transparent 40%, rgba(0, 255, 136, 0.06) 50%, transparent 60%);
    transition: transform 0.6s ease;
  }
  .cert-card:hover {
    transform: translateY(-5px);
    border-color: var(--border-h);
    box-shadow: var(--glow);
  }
  .cert-card:hover::after { transform: translate(33%, 33%); }

  .cert-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
  }
  .cert-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    background: rgba(0, 255, 136, 0.04);
    overflow: hidden;
  }
  .cert-icon img { width: 100%; height: 100%; object-fit: contain; }

  .cert-badge {
    font-family: var(--fmono);
    font-size: 0.62rem;
    padding: 0.2rem 0.6rem;
    letter-spacing: 1.5px;
    border-radius: 2px;
  }
  .cert-badge.cisco    { background: rgba(0,130,255,0.1); color: #4da6ff; border: 1px solid rgba(0,130,255,0.3); }
  .cert-badge.cyberops { background: rgba(255,130,0,0.1); color: #ff9933; border: 1px solid rgba(255,130,0,0.3); }
  .cert-badge.comptia  { background: rgba(220,50,50,0.12); color: #ff5555; border: 1px solid rgba(220,50,50,0.3); }
  .cert-badge.microsoft { background: rgba(0,100,220,0.12); color: #4d94ff; border: 1px solid rgba(0,100,220,0.3); }
  .cert-badge.fortinet { background: rgba(200,30,30,0.12); color: #ff4444; border: 1px solid rgba(200,30,30,0.3); }

  .cert-name {
    font-family: var(--forb);
    font-size: 0.82rem;
    color: var(--text1);
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 0.35rem;
    line-height: 1.35;
  }
  .cert-issuer {
    font-family: var(--fmono);
    font-size: 0.7rem;
    color: var(--text3);
    letter-spacing: 1px;
    margin-bottom: 0.9rem;
  }
  .cert-desc { font-size: 0.9rem; color: var(--text2); line-height: 1.65; flex: 1; }

  .cert-tags {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .cert-tag {
    font-family: var(--fmono);
    font-size: 0.63rem;
    padding: 0.2rem 0.55rem;
    border: 1px solid rgba(0, 212, 255, 0.2);
    color: var(--cyan-dim);
    background: rgba(0, 212, 255, 0.03);
  }

  @media (max-width: 768px) {
    .certs-grid { grid-template-columns: 1fr; }
  }
</style>
