<style>
  #skills { background: var(--bg0); }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 3.5rem;
  }
  .skill-cat {
    background: rgba(0, 255, 136, 0.02);
    border: 1px solid var(--border);
    padding: 2rem;
    position: relative;
  }
  .skill-cat::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(180deg, var(--green), transparent);
  }
  .skill-cat-title {
    font-family: var(--forb);
    font-size: 0.75rem;
    color: var(--green);
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .skill-item { margin-bottom: 1.3rem; }
  .skill-hdr {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.45rem;
  }
  .skill-name { font-family: var(--fmono); font-size: 0.8rem; color: var(--text2); }
  .skill-pct  { font-family: var(--fmono); font-size: 0.72rem; color: var(--green); }
  .skill-bar  { height: 3px; background: rgba(255, 255, 255, 0.05); overflow: hidden; }
  .skill-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--green), var(--cyan));
    transition: width 1.3s cubic-bezier(0.25, 1, 0.5, 1);
    position: relative;
  }
  .skill-fill::after {
    content: '';
    position: absolute;
    right: 0;
    top: -2px;
    width: 7px;
    height: 7px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 8px #fff, 0 0 14px var(--green);
  }

  .tools-wrap { text-align: center; }
  .tools-title {
    font-family: var(--forb);
    font-size: 0.75rem;
    color: var(--green);
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
  }
  .tools-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }
  .tool-tag {
    font-family: var(--fmono);
    font-size: 0.73rem;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border);
    color: var(--text2);
    background: rgba(0, 0, 0, 0.3);
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: default;
  }
  .tool-tag:hover {
    border-color: var(--green);
    color: var(--green);
    background: rgba(0, 255, 136, 0.05);
    box-shadow: 0 0 12px rgba(0, 255, 136, 0.12);
  }

  @media (max-width: 768px) {
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
