</section>

<style>
  #contact { background: var(--bg0); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .contact-h3 {
    font-family: var(--forb);
    font-size: 1.1rem;
    color: var(--text1);
    letter-spacing: 2px;
    margin-bottom: 1rem;
  }
  .contact-p { color: var(--text2); line-height: 1.85; margin-bottom: 2rem; font-size: 1rem; }

  .contact-items { display: flex; flex-direction: column; gap: 0.8rem; }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--border);
    background: rgba(0, 255, 136, 0.02);
    transition: all 0.3s;
  }
  .contact-item:hover {
    border-color: var(--border-h);
    background: rgba(0, 255, 136, 0.05);
  }
  .contact-item i { color: var(--green); font-size: 1.05rem; width: 20px; text-align: center; }
  .ci-label { font-family: var(--fmono); font-size: 0.62rem; color: var(--text3); letter-spacing: 1px; }
  .ci-value { font-family: var(--fmono); font-size: 0.82rem; color: var(--text2); }
  .ci-value a { color: var(--cyan); }
  .ci-value a:hover { color: var(--green); }

  .social-links { display: flex; gap: 0.8rem; margin-top: 2rem; }
  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--border);
    color: var(--text2);
    font-size: 1rem;
    transition: all 0.3s;
    background: rgba(0, 0, 0, 0.3);
  }
  .social-btn:hover {
    border-color: var(--green);
    color: var(--green);
    box-shadow: var(--glow);
    background: rgba(0, 255, 136, 0.06);
  }

  /* Terminal */
  .contact-terminal {
    background: var(--bg2);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .term-header {
    background: var(--bg3);
    padding: 0.8rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .term-label {
    font-family: var(--fmono);
    font-size: 0.7rem;
    color: var(--text3);
    margin-left: 0.5rem;
  }
  .term-body {
    padding: 1.5rem;
    font-family: var(--fmono);
    font-size: 0.8rem;
    line-height: 2;
  }
  .tp { color: var(--green); }
  .tc { color: var(--text2); }
  .to { color: var(--cyan); }
  .ts { color: #00ff88; }
  .tblank { height: 0.5rem; }
  .t-cursor { animation: blink 0.8s step-end infinite; color: var(--green); }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
