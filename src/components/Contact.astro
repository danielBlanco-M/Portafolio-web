                <a href="mailto:danielblanco2211@gmail.com">danielblanco2211@gmail.com</a>
              </div>
            </div>
          </div>
          <div class="contact-item">
            <i class="fab fa-linkedin"></i>
            <div>
              <div class="ci-label">LINKEDIN</div>
              <div class="ci-value">
                <a href="https://linkedin.com/in/daniel-blanco-8622a033b" target="_blank" rel="noopener noreferrer">
                  daniel-blanco-8622a033b
                </a>
              </div>
            </div>
          </div>
          <div class="contact-item">
            <i class="fab fa-github"></i>
            <div>
              <div class="ci-label">GITHUB</div>
              <div class="ci-value">
